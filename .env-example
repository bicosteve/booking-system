REDISHOST=127.0.0.1
REDISPORT=6379
REDISPASSWORD=
AUTHPORT=7001
AUTHBROKER=localhost:19092
AUTHTOPIC=bkgstmregister
AUTHKEY=register
DB_USER=bico 
DB_PASSWORD=***
DB_HOST=localhost
DB_NAME=***
DB_PORT=3306

# Production managed services (set on the EC2 .env)
# Kafka (Aiven): SASL over TLS / SCRAM
KAFKA_BROKER=
KAFKA_KEY=
KAFKA_TOPIC=
KAFKA_STATUS=0
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=SCRAM-SHA-256
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_CA_PEM=
KAFKA_CA_LOCATION=
# Redis (Upstash): TLS
REDIS_NAME=
REDIS_ADDRESS=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=true
# RabbitMQ: off by default; optional AMQPS if re-enabled
RABBITMQ_HOST=
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=
RABBITMQ_QUEUE=
RABBITMQ_STATUS=0
RABBIT_TLS=false
RABBIT_CA_PEM=
RABBIT_CA_LOCATION=



